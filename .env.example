APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_URL=http://localhost:8000

MASTER_API_URL=https://master.infiatin.cloud/api/v1
MASTER_API_CLIENT_ID=
MASTER_API_CLIENT_SECRET=
MASTER_API_CACHE_MINUTES=60
MASTER_API_TOKEN=
MASTER_API_TIMEOUT=10
MASTER_WEBHOOK_SECRET=
MASTER_WEBHOOK_WINDOW_SECONDS=600

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────
# This application uses MULTIPLE database connections:
# - `kkn`: Main application database (default)
# - `master`: External master data (SIKAD integration)
# ─────────────────────────────────────────────────────────────

# Default Connection (KKN Database)
DB_CONNECTION=kkn
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=kkn
DB_USERNAME=your_postgres_username
DB_PASSWORD=

# KKN Database (explicit connection for models using $connection = 'kkn')
DB_KKN_HOST=127.0.0.1
DB_KKN_PORT=5433
DB_KKN_DATABASE=kkn
DB_KKN_USERNAME=your_postgres_username
DB_KKN_PASSWORD=
DB_KKN_SCHEMA=public

# Master Database (External SIKAD API database)
DB_MASTER_HOST=master.infiatin.cloud
DB_MASTER_PORT=5432
DB_MASTER_DATABASE=master_db
DB_MASTER_USERNAME=kkn_user
DB_MASTER_PASSWORD=
DB_MASTER_SCHEMA=public

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=
# Untuk rebutan kelompok skala besar, arahkan dua hot path ini ke `redis`
# setelah Redis siap dipakai di environment kampus.
# REGISTRATION_LOCK_CACHE_STORE=redis
# REGISTRATION_SNAPSHOT_CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="kkn@uinsaizu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Configuration for Production
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=kkn@uinsaizu.ac.id
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Gunakan tanda kutip jika password mengandung karakter seperti `#`.
KKN_LOCAL_SEED_PASSWORD="Password#123"

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
# VITE_MASTER_API_URL is intentionally omitted to avoid exposing internal API URL to frontend

# API Key Distribution System
API_ADMIN_SECRET=
API_SELF_SERVICE_ENABLED=false

# Optional local-only seed password. Leave empty to generate random passwords
# for sample accounts when running seeders in local environment.
KKN_LOCAL_SEED_PASSWORD=
