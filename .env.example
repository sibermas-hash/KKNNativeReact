APP_NAME="KKN UIN Saizu"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_URL=http://localhost:8000

MASTER_API_URL=
MASTER_API_CLIENT_ID=
MASTER_API_CLIENT_SECRET=
MASTER_API_CACHE_MINUTES=60
MASTER_API_TOKEN=
MASTER_API_TIMEOUT=30
MASTER_API_CIRCUIT_BREAKER_THRESHOLD=5
MASTER_API_CIRCUIT_BREAKER_TIMEOUT=300
MASTER_API_RETRY_MAX_ATTEMPTS=3
MASTER_API_RETRY_INITIAL_DELAY=300

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# SECURITY NOTE: In production, set `expose_php = Off` in php.ini to hide PHP version from response headers.
# This is a php.ini setting, not a .env setting.

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────
# This application uses a single PostgreSQL database (pgsql).
# External master data is synced via API, not direct DB connection.
# ─────────────────────────────────────────────────────────────

# Default Connection (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kkn
DB_USERNAME=your_postgres_username
DB_PASSWORD=

# Master Database (External SIKAD - uncomment when direct DB sync is needed)
# DB_MASTER_HOST=master.infiatin.cloud
# DB_MASTER_PORT=5432
# DB_MASTER_DATABASE=master_db
# DB_MASTER_USERNAME=kkn_user
# DB_MASTER_PASSWORD=
# DB_MASTER_SCHEMA=public

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true # Set to false only for local development without HTTPS
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=
# Untuk rebutan kelompok skala besar, arahkan dua hot path ini ke `redis`
# setelah Redis siap dipakai di environment kampus.
# REGISTRATION_LOCK_CACHE_STORE=redis
# REGISTRATION_SNAPSHOT_CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your-redis-password-here
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="kkn@uinsaizu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Configuration for Production
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=kkn@uinsaizu.ac.id
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Gunakan tanda kutip jika password mengandung karakter seperti `#`.
# PENTING: Ganti dengan password kuat unik untuk environment lokal!
KKN_LOCAL_SEED_PASSWORD="<GENERATE_STRONG_PASSWORD_HERE>"

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
# VITE_MASTER_API_URL is intentionally omitted to avoid exposing internal API URL to frontend

# API Key Distribution System
API_ADMIN_SECRET=
API_SELF_SERVICE_ENABLED=false
API_KEY_RATE_LIMIT=60

# Campus API (SIKAD Integration)
CAMPUS_API_BASE_URL=
CAMPUS_API_KEY=
CAMPUS_API_ENABLED=false

# Admin email for rate limiting exceptions
ADMIN_EMAIL=admin@uinsaizu.ac.id

# Backup notification email (must be set in production)
BACKUP_NOTIFICATION_EMAIL=

# CORS allowed origins (comma-separated list)
# Untuk mobile, tambahkan: capacitor://localhost,http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,capacitor://localhost,http://localhost

# Sanctum token expiration in minutes (43200 = 30 days)
SANCTUM_TOKEN_EXPIRATION=43200

# ─────────────────────────────────────────────────────────────
# AI CONFIGURATION - Google Gemini 2.5
# ─────────────────────────────────────────────────────────────
# Provider: Google Generative AI (Gemini)
# Supported Models:
#   - gemini-2.5-flash (DEFAULT): Fast, accurate, cost-effective
#   - gemini-2.5-flash-lite: Ultra-fast, lightweight (for notifications)
#   - gemini-2.5-pro: Most capable (for complex analysis)
#
# Setup Guide: docs/GEMINI_AI_SETUP_GUIDE.md
# Get API Key: https://aistudio.google.com/apikey
#
# PRODUCTION DEPLOYMENT:
# ─────────────────────────────────────────────────────────────
# In production, API keys are managed ENTIRELY via Admin Panel:
#   Location: /admin/pengaturan-sistem → Tab "Monitor Intelegensi"
#   Storage: Encrypted in database (SystemSetting table)
#   No .env configuration needed!
#
# DEVELOPMENT / LOCAL TESTING:
# ─────────────────────────────────────────────────────────────
# For development, you can optionally set API key here for quick testing.
# Leave empty for production - use admin panel instead.
#
# How it works:
# 1. App checks database first (via AiConfigServiceProvider)
# 2. Fallback to .env if database value not found
# 3. Cache invalidated on admin panel update (no restart needed)
#
# Configuration Priority (Production):
#   1. Database (SystemSetting) - ✅ PRODUCTION USE THIS
#   2. .env (fallback) - Development only
#
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
