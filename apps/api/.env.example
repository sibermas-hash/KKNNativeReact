APP_NAME="KKN UIN Saizu"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# SIAKAD MASTER API (API UIN Saizu)
# ─────────────────────────────────────────────────────────────
# Token statis diberikan oleh Administrator SIAKAD.
# Jika IP diblokir Cloudflare (403), minta whitelist ke Admin Jaringan Kampus.
MASTER_API_URL=https://api.uinsaizu.ac.id
MASTER_API_TOKEN=
MASTER_API_TIMEOUT=30
MASTER_API_CIRCUIT_BREAKER_THRESHOLD=5
MASTER_API_CIRCUIT_BREAKER_TIMEOUT=300

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
HASHING_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kkn
DB_USERNAME=your_postgres_username
DB_PASSWORD=
# DB_SSLMODE=require  # aktifkan di production

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# REGISTRATION_LOCK_CACHE_STORE=redis
# REGISTRATION_SNAPSHOT_CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your-redis-password-here
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="kkn@uinsaizu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Production:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# PENTING: Ganti dengan password kuat unik!
KKN_LOCAL_SEED_PASSWORD="<GENERATE_STRONG_PASSWORD_HERE>"

VITE_APP_URL="${APP_URL}"

API_ADMIN_SECRET=
API_KEY_RATE_LIMIT=60

# SECURITY: Only enable in controlled test environments. NEVER true in production.
AUTH_TEST_AUTO_LOGIN_ENABLED=false

ADMIN_EMAIL=admin@uinsaizu.ac.id
BACKUP_NOTIFICATION_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,capacitor://localhost,http://localhost

SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_STATEFUL_DOMAINS=sibermas.uinsaizu.ac.id,localhost,localhost:3000

AI_PROVIDER=gemini
GEMINI_API_KEY=
