Audit Log Intelijen Sistem\">\n <Head title=\"Audit Log\"/>\n\n <div className=\"max-w-[1600px] mx-auto space-y-12 pb-24 font-sans px-4 sm:px-6 lg:px-8 text-gray-900\">\n \n {/* --- PREMIUM HEADER --- */}\n <div className=\"space-y-6 pt-12\">\n <div className=\"flex items-center gap-3 text-[#1a7a4a]\">\n <History size={20} />\n <span className=\"text-xs font-semibold opacity-80\">Chronological Integrity Audit</span>\n </div>\n <div className=\"flex flex-col lg:flex-row lg:items-end justify-between gap-8\">\n <div className=\"space-y-2\">\n <h1 className=\"text-4xl font-semibold text-gray-900 er leading-none\">\n Intelijen <span className=\"text-[#1a7a4a]\">Sistem.</span>\n </h1>\n <p className=\"text-sm font-semibold text-gray-700 leading-relaxed max-w-2xl mt-4\">\n Audit jejak aktivitas sistem secara immutable. Pantau seluruh anomali dan intervensi data melalui aliran kronologis yang terenkripsi untuk akuntabilitas operasional.\n </p>\n </div>\n <div className=\"shrink-0\">\n <div className=\"h-20 px-10 bg-white border border-emerald-800 rounded-xl flex items-center gap-8 text-white shadow-sm shadow-emerald-900/40\">\n <div className=\"flex flex-col\">\n <span className=\"text-xs font-semibold text-gray-700 leading-none mb-2\">Populasi Record</span>\n <span className=\"text-2xl font-semibold text-white tabular-nums leading-none\">{stats.total.toLocaleString('id-ID')} LOGS</span>\n </div>\n <div className=\"w-px h-10 bg-white/10\"/>\n <Terminal size={28} className=\"text-gray-700 drop-shadow-sm\"/>\n </div>\n </div>\n </div>\n </div>\n\n {/* --- STATS OVERVIEW --- */}\n <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n <MetricCard label=\"Pengguna Aktif\"value={stats.unique_users} icon={User} desc=\"Authorized Actors\"/>\n <MetricCard label=\"Aktivitas Harian\"value={stats.today_logs} icon={Activity} desc=\"Daily Sequence\"/>\n <MetricCard label=\"Risiko Tinggi\"value={stats.high_risk} icon={ShieldAlert} type={stats.high_risk > 0 ? 'danger' : 'success'} desc=\"Security Anomaly\"/>\n <MetricCard label=\"Kernel Pipeline\"value=\"STABIL\"icon={Cpu} desc=\"System Performance\"/>\n </div>\n\n {/* --- DATA TABLE CARD --- */}\n <section className=\"bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col\">\n <div className=\"px-10 py-10 bg-gray-50 border-b-2 border-gray-200 space-y-8\">\n <div className=\"flex items-center gap-4\">\n <div className=\"h-12 w-12 bg-white rounded-xl border border-gray-200 flex items-center justify-center text-[#1a7a4a] shadow-sm\">\n <Binary size={24} strokeWidth={2.5} />\n </div>\n <div className=\"flex flex-col\">\n <h3 className=\"text-lg font-semibold text-gray-900 leading-none mb-1\">Audit Stream</h3>\n <p className=\"text-xs font-bold text-gray-700\">Aliran Aktivitas Kronologis Real-Time</p>\n </div>\n </div>\n\n <form onSubmit={handleSearch} className=\"relative group\">\n <Search className=\"absolute left-5 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-600 group-focus-within:text-[#1a7a4a] transition-colors\"strokeWidth={3} />\n <input \n type=\"text\"\n value={search} \n onChange={(e) => setSearch(e.target.value)} \n placeholder=\"CARI IDENTIFIER, AKSI, ATAU AKTOR...\"\n className=\"w-full h-14 pl-14 pr-6 bg-white border border-gray-200 rounded-xl text-xs font-semibold text-gray-900 focus:border-[#1a7a4a] outline-none transition-all placeholder:text-gray-400 shadow-sm\"\n />\n </form>\n </div>\n\n <div className=\"overflow-x-auto min-h-[500px]\">\n <table className=\"min-w-full text-left border-collapse whitespace-nowrap\">\n <thead className=\"bg-gray-50 text-gray-900 border-b border-gray-200\">\n <tr>\n <th className=\"px-10 py-6 text-xs font-semibold\">Node ID</th>\n <th className=\"px-8 py-6 text-xs font-semibold\">Deskripsi Aktivitas</th>\n <th className=\"px-8 py-6 text-xs font-semibold text-center\">Otoritas Aktor</th>\n <th className=\"px-8 py-6 text-xs font-semibold text-center\">Subjek Event</th>\n <th className=\"px-10 py-6 text-right text-xs font-semibold\">Runtime</th>\n </tr>\n </thead>\n <tbody className=\"divide-y divide-[#f3f4f6]\">\n {logs.data.length === 0 ? (\n <EmptyState />\n ) : (\n logs.data.map((log) => (\n <tr key={log.id} className={clsx(\n\"group hover:bg-gray-50 transition-all font-sans\",\n log.severity === 'high' ? 'bg-rose-50/20' : log.severity === 'medium' ? 'bg-amber-50/10' : ''\n )}>\n <td className=\"px-10 py-8\">\n <span className=\"text-xs font-semibold text-gray-500 group-hover:text-gray-700 transition-colors font-mono\">#{log.id.toString().padStart(6, '0')}</span>\n </td>\n <td className=\"px-8 py-8\">\n <div className=\"flex items-center gap-5\">\n <div className={clsx(\n\"h-12 w-12 rounded-xl flex items-center justify-center transition-all shadow-sm border shrink-0 group-hover:rotate-6\",\n log.severity === 'high' ? 'bg-rose-50 border-rose-100 text-rose-500 group-hover:bg-rose-500 group-hover:text-white' : \n log.severity === 'medium' ? 'bg-amber-50 border-amber-100 text-amber-500 group-hover:bg-amber-500 group-hover:text-white' : \n 'bg-gray-50 border-gray-200 text-[#1a7a4a] group-hover:bg-[#16a34a] group-hover:text-white'\n )}>\n {log.severity === 'high' ? <ShieldAlert size={22} strokeWidth={2.5} /> : <Activity size={22} strokeWidth={2.5} />}\n </div>\n <div className=\"flex flex-col gap-2\">\n <span className=\"text-sm font-semibold text-gray-900 group-hover:text-gray-700 transition-colors leading-tight max-w-[400px] truncate\">{log.description}</span>\n <span className={clsx(\n\"text-xs font-semibold\",\n log.severity === 'high' ? 'text-rose-500' : log.severity === 'medium' ? 'text-amber-500' : 'text-gray-700'\n )}>{log.action}</span>\n </div>\n </div>\n </td>\n <td className=\"px-8 py-8 text-center text-center\">\n <div className=\"flex flex-col items-center\">\n <span className=\"text-xs font-semibold text-[#1f2937] leading-none mb-2\">{log.user?.name || 'SYSTEM_DAEMON'}</span>\n <span className=\"px-3 py-1 bg-white border border-gray-200 rounded-lg text-xs font-semibold text-gray-600\">AUTHORIZED_ACTOR</span>\n </div>\n </td>\n <td className=\"px-8 py-8 text-center\">\n <span className=\"h-8 px-4 inline-flex items-center bg-white border border-gray-200 rounded-xl text-xs font-semibold text-[#1a7a4a] shadow-sm\">\n {log.subject_type?.split('\\\\').pop() || 'STATIC_EVENT'}\n </span>\n </td>\n <td className=\"px-10 py-8 text-right whitespace-nowrap\">\n <div className=\"flex flex-col items-end gap-3\">\n <span className=\"text-xs font-semibold text-[#1a7a4a] font-mono\">{log.created_at}</span>\n <Link href={route('admin.audit-log.show', log.id)} className=\"text-xs font-semibold text-gray-600 hover:text-gray-900 flex items-center gap-2 group-hover:translate-x-0 translate-x-4 transition-all opacity-0 group-hover:opacity-100\">\n INSPECT_PACKET <ArrowRight size={12} strokeWidth={3} />\n </Link>\n </div>\n </td>\n </tr>\n ))\n )}\n </tbody>\n </table>\n </div>\n\n {/* PAGINATION */}\n <div className=\"px-10 py-8 border-t-2 border-gray-200 bg-gray-50 flex items-center justify-between\">\n <span className=\"text-xs font-semibold text-gray-700\">\n Transmission Stage <strong className=\"text-gray-900 text-xs tabular-nums\">{logs.meta.current_page}</strong> OF <strong className=\"text-gray-900 text-xs tabular-nums\">{logs.meta.last_page}</strong> Active Frames\n </span>\n <Pagination meta={logs.meta} />\n </div>\n </section>\n\n {/* --- GOVERNANCE FOOTER --- */}\n <div className=\"bg-white rounded-xl p-12 text-white relative overflow-hidden shadow-sm border border-emerald-800 group/governance\">\n <div className=\"absolute top-0 right-0 p-12 opacity-10 rotate-12 -mr-32 -mt-32 transition-transform group-hover/governance:rotate-45 duration-1000\">\n <Cpu size={500} strokeWidth={0.5} />\n </div>\n <div className=\"flex flex-col lg:flex-row items-center justify-between gap-12 relative z-10\">\n <div className=\"space-y-6 flex-1\">\n <div className=\"flex items-center gap-6\">\n <div className=\"h-20 w-20 bg-gray-100/50 rounded-xl flex items-center justify-center shrink-0 border border-emerald-800 shadow-inner group-hover/governance:scale-110 transition-transform\">\n <ShieldCheck size={40} className=\"text-gray-700\"strokeWidth={2.5} />\n </div>\n <div className=\"flex flex-col\">\n <h3 className=\"text-2xl font-semibold leading-none mb-1\">Integritas Log Kronologis</h3>\n <span className=\"text-xs font-semibold text-gray-700 opacity-80\">Protokol Keamanan Data Transparan</span>\n </div>\n </div>\n <p className=\"text-sm font-bold text-gray-700 leading-relaxed max-w-4xl\">\n Seluruh aktivitas dalam infrastruktur SIKKKN UIN SAIZU dicatat secara immutable melalui arsitektur audit log ini. Sistem ini menjamin transparansi operasional, akuntabilitas personil, dan integritas metadata KKN dari awal pendaftaran hingga yudisium akhir. Intervensi tanpa otorisasi akan memicu sinyal risiko tinggi secara otomatis.\n </p>\n </div>\n </div>\n </div>\n </div>\n </AppLayout>\n );\n}\n\nfunction MetricCard({ label, value, icon: Icon, desc, type }: { label: string; value: any; icon: any; desc: string; type?: 'success' | 'danger' }) {\n return (\n <div className=\"bg-white border border-gray-200 rounded-xl p-6 flex items-center gap-5 shadow-sm hover:border-gray-200 transition-all group overflow-hidden relative\">\n <div className={clsx(\n\"h-14 w-14 rounded-xl flex items-center justify-center shrink-0 group-hover:scale-110 group-hover:rotate-6 transition-all shadow-sm border\",\n type === 'danger' ? 'bg-rose-50 border-rose-100 text-rose-500' : 'bg-gray-50 border-gray-200 text-[#1a7a4a]'\n )}>\n <Icon size={24} strokeWidth={2.5} />\n </div>\n <div className=\"flex flex-col relative z-20\">\n <span className=\"text-xs font-semibold text-gray-700 leading-none mb-3\">{label}</span>\n <span className=\"text-2xl font-semibold text-gray-900 er leading-none group-hover:text-gray-700 transition-colors mb-1.5\">{value}</span>\n <p className=\"text-xs font-semibold text-gray-600 opacity-60 leading-none\">{desc}</p>\n </div>\n </div>\n );\n}\n\nfunction EmptyState() {\n return (\n <tr>\n <td colSpan={10} className=\"px-10 py-32 text-center\">\n <div className=\"flex flex-col items-center justify-center gap-4\">\n <div className=\"h-24 w-24 bg-gray-50 rounded-xl flex items-center justify-center text-gray-700 mb-2\">\n <SearchCode size={48} strokeWidth={1} />\n </div>\n <span className=\"text-sm font-semibold text-gray-900\">Audit Silence</span>\n <p className=\"text-xs font-semibold text-gray-700 leading-none opacity-60\">Tidak ditemukan aliran transmisi log untuk parameter pencarian saat ini.</p>\n </div>\n </td>\n </tr>\n );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/macm4/Documents/Projek/KKN/kknuinsaizu/resources/js/Pages/Admin/Monitoring/AuditLog/Show.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'clsx' is defined but never used. Allowed unused vars must match /^_/u.","line":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":14,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"clsx"},"fix":{"range":[204,233],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Head, Link } from '@inertiajs/react';\nimport AppLayout from '@/Layouts/AppLayout';\nimport { route } from 'ziggy-js';\nimport { ChevronLeft, Clock, User, Layers, Code2, Info } from 'lucide-react';\nimport { clsx } from 'clsx';\n\ninterface AuditLog {\n id: number; description: string; subject_type: string | null; subject_id: number | null;\n causer_type: string | null; causer_id: number | null; causer?: { name: string };\n properties: Record<string, unknown>; created_at: string;\n}\ninterface Props { log: AuditLog; }\n\nexport default function AuditLogShow({ log }: Props) {\n const subjectModel = log.subject_type?.split('\\\\').pop() || 'Sistem';\n const causerModel = log.causer_type?.split('\\\\').pop() || 'Internal';\n\n return (\n <AppLayout title=\"Detail Log Aktivitas\">\n <Head title={`Detail Log #${log.id} | POS-KKN`} />\n\n <div className=\"min-h-screen bg-gray-50/50 pb-20\">\n {/* Header */}\n <div className=\"bg-white border-b border-gray-200/60\">\n <div className=\"max-w-[1600px] mx-auto px-8 py-6\">\n <div className=\"flex items-center gap-6\">\n <Link href={route('admin.audit-log.index')} className=\"h-12 w-12 rounded-xl bg-gray-50 text-gray-900 hover:bg-[#16a34a] hover:text-white flex items-center justify-center transition-all active:scale-90 border border-gray-200/60\">\n <ChevronLeft size={20} />\n </Link>\n <div className=\"space-y-3\">\n <div className=\"flex items-center gap-3\">\n <div className=\"h-2 w-2 bg-gray-500 rounded-full\"/>\n <span className=\"text-xs font-semibold text-[#1a7a4a] font-semibold text-xs\">Detail Aktivitas</span>\n </div>\n <h1 className=\"text-3xl font-semibold text-black\">\n Log <span className=\"text-[#1a7a4a]\">#{log.id.toString().padStart(6, '0')}</span>\n </h1>\n <p className=\"text-gray-900 text-base font-medium\">\n Analisis perubahan data dan aktor yang terlibat dalam aktivitas ini.\n </p>\n </div>\n </div>\n </div>\n </div>\n\n <div className=\"max-w-[1600px] mx-auto px-8 mt-8\">\n <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-8\">\n {/* Main */}\n <div className=\"xl:col-span-8 space-y-8\">\n {/* Description */}\n <div className=\"bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden\">\n <div className=\"px-8 py-6 border-b border-gray-200/60 bg-gray-50/30 flex items-center gap-5\">\n <div className=\"h-12 w-12 rounded-xl bg-gray-50 text-[#1a7a4a] flex items-center justify-center border border-gray-200 shadow-sm\">\n <Info size={22} />\n </div>\n <div>\n <h2 className=\"text-base font-bold text-black\">Ringkasan Aktivitas</h2>\n <p className=\"text-sm text-gray-900 mt-0.5\">Deskripsi dan waktu kejadian</p>\n </div>\n </div>\n <div className=\"p-8 space-y-6\">\n <p className=\"text-lg font-bold text-black\">{log.description}</p>\n <div className=\"flex items-center gap-3 text-gray-900\">\n <Clock size={16} />\n <span className=\"text-sm font-medium tabular-nums\">{log.created_at}</span>\n </div>\n </div>\n </div>\n\n {/* Info Cards */}\n <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n <InfoCard label=\"Aktor\"value={log.causer?.name || 'Sistem'} sub={`Tipe: ${causerModel}`} icon={User} />\n <InfoCard label=\"Subjek\"value={subjectModel} sub={log.subject_id ? `ID: #${log.subject_id}` : 'Tidak ada ID subjek'} icon={Layers} />\n </div>\n\n {/* Properties JSON */}\n <div className=\"bg-white rounded-xl border border-gray-200/60 shadow-sm overflow-hidden\">\n <div className=\"px-8 py-6 border-b border-gray-200/60 bg-gray-50/30 flex items-center gap-5\">\n <div className=\"h-12 w-12 rounded-xl bg-gray-50 text-gray-900 flex items-center justify-center border border-gray-200/60 shadow-sm\">\n <Code2 size={22} />\n </div>\n <div>\n <h2 className=\"text-base font-bold text-black\">Data Properti</h2>\n <p className=\"text-sm text-gray-900 mt-0.5\">Detail perubahan data dalam format JSON</p>\n </div>\n </div>\n <div className=\"p-6 bg-gray-100 rounded-b-3xl\">\n <pre className=\"text-sm text-white leading-relaxed overflow-x-auto whitespace-pre-wrap font-mono tabular-nums\">\n {JSON.stringify(log.properties, null, 4)}\n </pre>\n </div>\n </div>\n </div>\n\n {/* Sidebar */}\n <div className=\"xl:col-span-4 space-y-8\">\n <div className=\"bg-white rounded-xl border border-gray-200/60 shadow-sm p-8 space-y-6\">\n <h3 className=\"text-sm font-bold text-black\">Metadata</h3>\n <div className=\"space-y-4\">\n <MetaRow label=\"ID Subjek\"value={log.subject_id ? `#${log.subject_id.toString().padStart(4, '0')}` : '-'} />\n <MetaRow label=\"Tipe Aktor\"value={causerModel} />\n <MetaRow label=\"Aksi\"value={log.description.split(' ')[0]} />\n <MetaRow label=\"Modul\"value={subjectModel} />\n </div>\n </div>\n\n <div className=\"bg-gray-50 rounded-xl border border-gray-200 p-8 space-y-4\">\n <h3 className=\"text-sm font-bold text-bg-[#e8f5ee]\">Catatan</h3>\n <p className=\"text-sm text-gray-900 leading-relaxed\">\n Log ini bersifat permanen dan tidak dapat diubah. Seluruh data mutasi tercatat untuk menjamin akuntabilitas operasional sistem KKN.\n </p>\n </div>\n </div>\n </div>\n </div>\n </div>\n </AppLayout>\n );\n}\n\nfunction InfoCard({ label, value, sub, icon: Icon }: { label: string; value: string; sub: string; icon: React.ElementType }) {\n return (\n <div className=\"bg-white rounded-xl border border-gray-200/60 shadow-sm p-8 space-y-4\">\n <div className=\"flex items-center gap-4\">\n <div className=\"h-10 w-10 rounded-xl bg-gray-50 text-[#1a7a4a] flex items-center justify-center border border-gray-200\">\n <Icon size={18} />\n </div>\n <span className=\"text-xs font-bold text-gray-900 font-semibold text-xs\">{label}</span>\n </div>\n <p className=\"text-lg font-bold text-black\">{value}</p>\n <p className=\"text-xs text-gray-900\">{sub}</p>\n </div>\n );\n}\n\nfunction MetaRow({ label, value }: { label: string; value: string }) {\n return (\n <div className=\"flex items-center justify-between py-3 border-b border-slate-50 last:border-0\">\n <span className=\"text-xs font-semibold text-gray-900\">{label}</span>\n <span className=\"text-xs font-bold text-[#1a7a4a] bg-gray-50 px-3 py-1 rounded-lg border border-gray-200\">{value}</span>\n </div>\n );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/macm4/Documents/Projek/KKN/kknuinsaizu/resources/js/Pages/Admin/Monitoring/DailyReports/Index.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileSearch' is defined but never used. Allowed unused vars must match /^_/u.","line":15,"column":2,"nodeType":"Identifier","messageId":"unusedVar","endLine":15,"endColumn":12,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileSearch"},"fix":{"range":[258,271],"text":""},"desc":"Remove