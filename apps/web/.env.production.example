# ──────────────────────────────────────────────────────────────
# SIBERMAS Web — Production Environment
# ──────────────────────────────────────────────────────────────
# Copy to .env.production (or .env.local on the production server)
# and fill in the values before building.
#
# Path-based routing: Next.js (port 3000) dan Laravel API berbagi origin yang
# sama. Nginx mem-forward `/api/*` ke Laravel via alias+named location
# (lihat nginx-freebsd.conf).

NEXT_PUBLIC_API_URL=https://sibermas.uinsaizu.ac.id/api/v1
NEXT_PUBLIC_APP_URL=https://sibermas.uinsaizu.ac.id
NEXT_PUBLIC_SENTRY_DSN=
