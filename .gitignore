# ── Root ──────────────────────────────────────────────
node_modules/
.turbo/
.DS_Store
**/.DS_Store
*.log

# ── Debug/diagnostic files ──────────────────────────
pest_results.txt
route_list.txt
migrate_status.txt

# ── apps/api (Laravel) ──────────────────────────────
apps/api/vendor/
apps/api/node_modules/
apps/api/storage/logs/*
apps/api/storage/framework/cache/*
apps/api/storage/framework/sessions/*
apps/api/storage/framework/views/*
apps/api/storage/app/public/*
apps/api/storage/app/private/*
apps/api/bootstrap/cache/*
apps/api/.env
apps/api/.env.backup
apps/api/.env.production
apps/api/.env.testing
apps/api/.phpunit.result.cache
apps/api/.phpunit.cache/

# ── DebugBar
apps/api/storage/debugbar/*

# ── apps/web (Next.js) ─────────────────────────────
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/.env.local

# ── apps/mobile (Expo) ─────────────────────────────
apps/mobile/node_modules/
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/android/app/build/
apps/mobile/android/.gradle/
apps/mobile/ios/Pods/

# ── packages ────────────────────────────────────────
packages/*/node_modules/
packages/*/dist/

# ── Sensitive data ──────────────────────────────────
*.xlsx
*.xls
*.csv
*.sql
!template.xlsx
