#!/usr/bin/env expect -f
# SSH connection test (requires SSH key auth)
set timeout 30
log_file -a ./ssh_output.log
spawn ssh -p 1977 -o StrictHostKeyChecking=accept-new kampelmas@172.16.2.70 "whoami; hostname; pwd; echo SSH_SUCCESS"
expect {
    "SSH_SUCCESS" {
        puts "\nCONNECTION_OK"
    }
    timeout {
        puts "\nTIMEOUT_ERROR"
        exit 1
    }
    eof {
        puts "\nEOF_REACHED"
    }
}
wait
