#!/usr/bin/env expect -f
# SSH login test (requires SSH key auth)
# Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect test_login.exp
log_file ./test_login.log
set timeout 10
set env(SSH_USER) [expr {[info exists env(SSH_USER)] ? $env(SSH_USER) : "kampelmas"}]
set env(SSH_HOST) [expr {[info exists env(SSH_HOST)] ? $env(SSH_HOST) : "172.16.2.70"}]
set env(SSH_PORT) [expr {[info exists env(SSH_PORT)] ? $env(SSH_PORT) : "1977"}]
spawn ssh -p $env(SSH_PORT) -o StrictHostKeyChecking=accept-new $env(SSH_USER)@$env(SSH_HOST)
expect {
    "*$" {
        send "echo LOGGED_IN_SUCCESS\r"
        expect "LOGGED_IN_SUCCESS"
        send "exit\r"
        puts "SUCCESS_LOGIN"
    }
    timeout {
        puts "TIMEOUT"
        exit 1
    }
    eof {
        puts "EOF"
    }
}
