#!/usr/bin/env expect -f
# SSH login test (requires SSH key auth)
# Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect test_login.exp
log_file ./test_login.log
set timeout 10

foreach var {SSH_USER SSH_HOST SSH_PORT} {
    if {![info exists env($var)] || $env($var) eq ""} {
        puts stderr "ERROR: $var environment variable required."
        puts stderr "Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect test_login.exp"
        exit 2
    }
}

spawn ssh -p $env(SSH_PORT) -o StrictHostKeyChecking=accept-new $env(SSH_USER)@$env(SSH_HOST)
expect {
    "*$" {
        send "echo LOGGED_IN_SUCCESS\r"
        expect "LOGGED_IN_SUCCESS"
        send "exit\r"
        puts "SUCCESS_LOGIN"
    }
    timeout {
        puts "TIMEOUT"
        exit 1
    }
    eof {
        puts "EOF"
    }
}
