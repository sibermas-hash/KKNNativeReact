#!/usr/bin/env expect -f
# SSH connection test (requires SSH key auth)
# Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect ssh_test.exp
set timeout 30

# Require env vars — no hardcoded defaults (avoid leaking internal IPs/users
# if this repo becomes public).
foreach var {SSH_USER SSH_HOST SSH_PORT} {
    if {![info exists env($var)] || $env($var) eq ""} {
        puts stderr "ERROR: $var environment variable required."
        puts stderr "Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect ssh_test.exp"
        exit 2
    }
}

log_file -a ./ssh_output.log
spawn ssh -p $env(SSH_PORT) -o StrictHostKeyChecking=accept-new $env(SSH_USER)@$env(SSH_HOST) "whoami; hostname; pwd; echo SSH_SUCCESS"
expect {
    "SSH_SUCCESS" {
        puts "\nCONNECTION_OK"
    }
    timeout {
        puts "\nTIMEOUT_ERROR"
        exit 1
    }
    eof {
        puts "\nEOF_REACHED"
    }
}
wait
