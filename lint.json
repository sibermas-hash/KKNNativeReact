book</h3>\n <p className=\"text-xs text-gray-500 leading-relaxed max-w-3xl\">\n Seluruh interaksi laporan dipantau permanen dalam log sistem. DPL diwajibkan memberikan feedback akurat.\n </p>\n </div>\n </div>\n <div className=\"text-xs font-bold text-gray-700 bg-white px-3 py-1.5 rounded border border-emerald-800 shrink-0 hidden sm:block\">\n SISTEM AKTIF\n </div>\n </div>\n </div>\n </AppLayout>\n );\n}\n\nfunction MetricCard({ label, value, icon: Icon, desc }: { label: string; value: any; icon: any; desc: string }) {\n return (\n <div className=\"bg-white border border-gray-200 rounded-xl p-4 flex items-center gap-4 shadow-sm relative\">\n <div className=\"h-10 w-10 shrink-0 rounded-lg flex items-center justify-center text-[#1a7a4a] bg-gray-50 border border-gray-200\">\n <Icon size={18} strokeWidth={2.5} />\n </div>\n <div className=\"flex flex-col\">\n <span className=\"text-xs font-bold text-[#1a7a4a]\">{label}</span>\n <span className=\"text-lg font-semibold text-gray-900 leading-tight truncate\">{value}</span>\n </div>\n </div>\n );\n}\n\nfunction EmptyState() {\n return (\n <tr>\n <td colSpan={10} className=\"px-6 py-16 text-center\">\n <div className=\"flex flex-col items-center justify-center gap-3\">\n <div className=\"h-16 w-16 bg-gray-50 rounded-xl flex items-center justify-center text-gray-600 border border-gray-200\">\n <SearchCode size={28} strokeWidth={1.5} />\n </div>\n <span className=\"text-sm font-bold text-[#1f2937]\">Data Logbook Nihil</span>\n <p className=\"text-xs text-[#1a7a4a]\">Tidak ada data transmisi laporan pada filter sistem saat ini.</p>\n </div>\n </td>\n </tr>\n );\n}\n\n","usedDeprecatedRules":[]},{"filePath":"/Users/macm4/Documents/Projek/KKN/kknuinsaizu/resources/js/Pages/Admin/Monitoring/FinalReports/Index.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/macm4/Documents/Projek/KKN/kknuinsaiz