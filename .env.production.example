.env.production.example
================================================================================

# APPLICATION SETTINGS
APP_NAME="KKN UIN SAIZU"
APP_ENV=production
APP_KEY=base64:insert-generated-key-here
APP_DEBUG=false
APP_URL=https://yourdomain.com
FORCE_HTTPS=true

# DEBUGBAR & MONITORING
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false
LOG_CHANNEL=daily
LOG_LEVEL=warning

# DATABASE - PRIMARY (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db.yourdomain.com
DB_PORT=5432
DB_DATABASE=kkn_production
DB_USERNAME=kkn_app
DB_PASSWORD=<GENERATE_STRONG_PASSWORD_HERE>
DB_SSLMODE=require

# DATABASE - SECONDARY (MySQL for backup)
DB_CONNECTION_SECONDARY=mysql
DB_HOST_SECONDARY=mysql.yourdomain.com
DB_PORT_SECONDARY=3306
DB_DATABASE_SECONDARY=kkn_backup
DB_USERNAME_SECONDARY=kkn_app_mysql
DB_PASSWORD_SECONDARY=<GENERATE_STRONG_PASSWORD_HERE>

# REDIS CACHE
REDIS_HOST=redis.yourdomain.com
REDIS_PASSWORD=<GENERATE_STRONG_PASSWORD_HERE>
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=cookie
QUEUE_CONNECTION=redis

# SESSION & COOKIES
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=yourdomain.com

# QUEUE PROCESSING
QUEUE_CONNECTION=redis

# MAIL CONFIGURATION (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=<GENERATE_STRONG_PASSWORD_HERE>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="KKN UIN SAIZU - Do Not Reply"

# Alternative email providers (choose one):

# SendGrid:
# MAIL_MAILER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-key

# AWS SES:
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# Brevo (ex-Sendinblue):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-brevo-email@example.com
# MAIL_PASSWORD=your-brevo-api-key

# AUTHENTICATION
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
SANCTUM_GUARD=sanctum
SANCTUM_TOKEN_EXPIRATION=525600

# JWT/TOKEN CONFIGURATION (if using)
JWT_SECRET=<GENERATE_STRONG_PASSWORD_HERE>
JWT_ALGORITHM=HS256

# STORAGE
FILESYSTEM_DISK=local
APP_STORAGE_PATH=/storage/uploads
BACKUP_DISK=s3

# AWS S3 (for backups/storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=<GENERATE_STRONG_PASSWORD_HERE>
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=kkn-production-bucket
AWS_USE_PATH_STYLE_URLS=false

# EXTERNAL SERVICES

# Sentry Error Tracking
SENTRY_LARAVEL_DSN=https://your-sentry-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# Firebase/Push Notifications (if using)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Maps API (for GPS features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SMS Gateway (if needed)
SMS_GATEWAY=twilio
TWILIO_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=<GENERATE_STRONG_PASSWORD_HERE>
TWILIO_PHONE_FROM=+62xxx

# SECURITY

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://sibermas.uinsaizu.ac.id,capacitor://localhost,http://localhost
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
CORS_EXPOSED_HEADERS=Authorization

# CAPTCHA (if using)
CAPTCHA_SECRET=<GENERATE_STRONG_PASSWORD_HERE>
CAPTCHA_SITEKEY=your-captcha-sitekey

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RESET_INTERVAL=3600

# OTP/2FA
OTP_LENGTH=6
OTP_VALIDITY_MINUTES=5
OTP_RESEND_INTERVAL=60

# ADMIN CONTACT
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PHONE=+62-xxx-xxxxx
SUPPORT_EMAIL=support@yourdomain.com
BACKUP_NOTIFICATION_EMAIL=admin@yourdomain.com

# LOGGING & MONITORING
APP_LOG_CHANNEL=daily
APP_LOG_SIZE=50  // MB
APP_LOG_DAYS=60  // Keep logs for N days

# PERFORMANCE
QUERY_TIMER_ENABLED=false
ENABLE_QUERY_LOGGING=false

# Feature Flags (for gradual rollout)
FEATURE_STUDENT_DASHBOARD_V2=false
FEATURE_ADVANCED_REPORTING=true
FEATURE_BULK_IMPORT=true

# MAINTENANCE MODE
MAINTENANCE_MODE=false
MAINTENANCE_SKIP_IPS=127.0.0.1,::1

# BACKUP CONFIGURATION
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily  // daily, weekly, manual
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true

# SSL/HTTPS
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
FORCE_HTTPS=true

# TIMEZONE
APP_TIMEZONE=Asia/Jakarta
TIMEZONE_ABBREVIATION=WIB

# LOGGING
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_CHANNEL=

# LOCALIZATION
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

================================================================================
SETUP INSTRUCTIONS:
================================================================================

1. Copy this file:
   cp .env.production.example .env.production
   cp .env.production .env  # For production deployment

2. Update values (CRITICAL):
   - APP_KEY (generate: php artisan key:generate)
   - DB_PASSWORD (use strong password, store in vault)
   - MAIL_* settings (verify with email provider)
   - AWS_* settings (if using S3)
   - URLs (yourdomain.com)

3. Verify settings:
   php artisan config:show | grep -E "APP_|DB_|MAIL_"

4. Test connections:
   - Database: php artisan db:seed --no-interaction
   - Mail: Write test file or use tinker
   - Redis: redis-cli -h redis.yourdomain.com ping

5. Store secrets:
   - Never commit .env to git
   - Use environment vault (AWS Secrets Manager, HashiCorp Vault)
   - Rotate keys quarterly

================================================================================
SECURITY CHECKLIST:
================================================================================

☐ APP_DEBUG=false (never true in production)
☐ FORCE_HTTPS=true (enforce SSL)
☐ APP_KEY is 32+ characters and random
☐ All passwords are strong (min 16 chars, mixed case + numbers + symbols)
☐ Database credentials stored in vault, not in git
☐ MAIL credentials verified and tested
☐ CORS settings restricted to known domains
☐ Rate limiting enabled
☐ Sentry DSN configured for error tracking
☐ Backup schedule configured
☐ Log files configured to rotate
☐ Sensitive values never logged

================================================================================
TESTING COMMANDS:
================================================================================

# Test database connection
php artisan db:show

# Test mail configuration
Mail::raw('Test email', function($m) {
    $m->to('test@example.com')->subject('Test Email');
});

# Check environment
php artisan tinker
env('APP_ENV')  // should return 'production'
env('APP_DEBUG') // should return false

# Verify rate limiting
php artisan config:show app

================================================================================
