# pnpm config.
#
# node-linker=hoisted memaksa pnpm membuat `node_modules` datar (mirip npm/yarn
# classic) alih-alih struktur symlink ke `.pnpm/`. Ini diperlukan untuk:
#
#   1. Next.js `output: 'standalone'` build. Standalone tracer pakai path
#      resolution klasik — kalau source asli ada di `.pnpm/<pkg>@<ver>/`,
#      banyak internal modul (contoh: `next/dist/lib/get-network-host`) yang
#      path-nya tidak ikut ter-copy ke dist/standalone. Akibatnya production
#      crash dengan "Cannot find module '../../lib/get-network-host'" saat
#      `node .next/standalone/server.js`.
#
#   2. Deployment ke FreeBSD / environment yang tidak mudah handle symlink
#      rekursif — beberapa filesystem behavior berbeda antar OS.
#
# Trade-off: disk lebih besar karena duplikasi paket antar app di monorepo.
# Untuk SIBERMAS ini dapat diterima (~200MB extra), demi build reproducibility.
#
# Alternatif (kalau ingin tetap symlink untuk hemat disk): set
# `node-linker=isolated` (default) + deploy pakai `pnpm run start --filter web`
# dari root (bukan standalone). Lihat docs/DEPLOY_NOTES.md.
node-linker=hoisted

# Gunakan workspace package dengan `workspace:*` specifier, bukan di-resolve
# ke versi registry. Sudah jadi default tapi eksplisit supaya tidak berubah
# saat update pnpm.
link-workspace-packages=true

# Strict peer dependency cek — biarkan warning saja supaya monorepo tetap
# bisa di-install. Set true di CI kalau ingin gate PR pada peer violations.
strict-peer-dependencies=false

# Hoist pattern default — pastikan package yang sering di-require secara
# dynamic (React, Next, TypeScript) selalu di root node_modules sehingga
# standalone build bisa trace path tanpa symlink.
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=@types/*
