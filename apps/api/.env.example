APP_NAME="KKN UIN Saizu"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# SIAKAD MASTER API (API UIN Saizu)
# ─────────────────────────────────────────────────────────────
# Token statis diberikan oleh Administrator SIAKAD.
# Jika IP diblokir Cloudflare (403), minta whitelist ke Admin Jaringan Kampus.
MASTER_API_URL=https://api.uinsaizu.ac.id
MASTER_API_TOKEN=
MASTER_API_TIMEOUT=30
MASTER_API_CIRCUIT_BREAKER_THRESHOLD=5
MASTER_API_CIRCUIT_BREAKER_TIMEOUT=300
# Auto-provision akun mahasiswa saat login pertama.
# OFF by default: helper NIM saat ini perlu stream feed mahasiswa dari SIAKAD
# karena filter server-side upstream belum reliabel.
MASTER_API_AUTO_PROVISION_LOGIN=false
MASTER_API_AUTO_PROVISION_COOLDOWN_SECONDS=900

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
HASHING_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kknnative
DB_USERNAME=kknuinsaizunative
DB_PASSWORD=
# DB_SSLMODE=require  # aktifkan di production

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=1200
DB_QUEUE_RETRY_AFTER=1200

CACHE_STORE=redis
# REGISTRATION_LOCK_CACHE_STORE=redis
# REGISTRATION_SNAPSHOT_CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=your-redis-password-here
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="kkn@uinsaizu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Production:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────
# PRODUCTION SUPERADMIN BOOTSTRAP
# ─────────────────────────────────────────────────────────────
# Set nilai ini sebelum menjalankan:
# php artisan db:seed --class=SuperAdminSeeder --force
# Gunakan password kuat unik, lalu rotasi/hapus dari secret env setelah akun siap bila perlu.
KKN_SUPERADMIN_USERNAME=superadmin
KKN_SUPERADMIN_NAME="Super Administrator SIBERMAS"
KKN_SUPERADMIN_EMAIL=superadmin@uinsaizu.ac.id
KKN_SUPERADMIN_PASSWORD=

VITE_APP_URL="${APP_URL}"

API_ADMIN_SECRET=
API_KEY_RATE_LIMIT=60

# SECURITY: Only enable in controlled test environments. NEVER true in production.
AUTH_TEST_AUTO_LOGIN_ENABLED=false

# 0 = strict enforcement dari detik pertama (default aman).
# Rekomendasi first launch: 24. Setelah operator terbiasa, set 0.

ADMIN_EMAIL=admin@uinsaizu.ac.id
BACKUP_NOTIFICATION_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,capacitor://localhost,http://localhost

SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_STATEFUL_DOMAINS=sibermas.uinsaizu.ac.id,localhost,localhost:3000

AI_PROVIDER=rizquna
RIZQUNA_URL="https://router.rizquna.id/v1"
RIZQUNA_API_KEY=
RIZQUNA_MODEL="ag/gemini-3-flash"

# Webhook signature secret for SIAKAD master data webhooks (required)
MASTER_WEBHOOK_SECRET=
MASTER_WEBHOOK_WINDOW_SECONDS=300

# Frontend URL for CORS and redirect links
APP_FRONTEND_URL=http://localhost:3000

# Sentry error tracking (optional)
SENTRY_LARAVEL_DSN=

# Sanctum token prefix (optional, for namespacing tokens)
SANCTUM_TOKEN_PREFIX=sibermas_

# PII blind-index HMAC key — generate: openssl rand -base64 32
APP_BLIND_INDEX_KEY=

# ─────────────────────────────────────────────────────────────
# AI FAILOVER CONFIG (Avatar Validation — PRD_AVATAR_VALIDATION.md)
# ─────────────────────────────────────────────────────────────
# Seluruh AI default ke Rizquna Router.
# Fallback/tertiary opsional untuk retry dengan key Rizquna lain.

AI_PRIMARY_URL="https://router.rizquna.id/v1"
AI_PRIMARY_KEY=
AI_PRIMARY_MODEL="ag/gemini-3-flash"

AI_FALLBACK_URL="https://router.rizquna.id/v1"
AI_FALLBACK_KEY=
AI_FALLBACK_MODEL="ag/gemini-3-flash"

AI_TERTIARY_URL="https://router.rizquna.id/v1"
AI_TERTIARY_KEY=
AI_TERTIARY_MODEL="ag/gemini-3-flash"

AI_ASSISTANT_PROVIDER=rizquna
AI_ASSISTANT_MODEL="ag/gemini-3-flash"
AI_ACTIVITY_REVIEWER_PROVIDER=rizquna
AI_ACTIVITY_REVIEWER_MODEL="ag/gemini-3-flash"
AI_CODE_PROVIDER=rizquna
AI_CODE_MODEL="cx/gpt-5.3-codex"
AI_SELF_HEALER_PROVIDER=rizquna
AI_SELF_HEALER_MODEL="cx/gpt-5.3-codex"

# Ops Monitoring (optional — leave blank to disable Telegram alerts)
# Bot token from @BotFather, chat_id negative for group chats
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

REVERB_APP_ID=sibermas
REVERB_APP_KEY=sibermas-local-key
REVERB_APP_SECRET=sibermas-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

NEXT_PUBLIC_REVERB_APP_KEY=sibermas-local-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http
