# ──────────────────────────────────────────────────────────────
# SIBERMAS — Production Environment Configuration
# ──────────────────────────────────────────────────────────────
# Salin file ini ke .env di server production dan sesuaikan nilai-nilainya.

APP_NAME="SIBERMAS"
APP_ENV=production
APP_KEY=              # php artisan key:generate
APP_DEBUG=false
DEBUGBAR_ENABLED=false
# Path-based routing (single domain, no api.* subdomain). Nginx mem-proxy
# `/api/*` ke Laravel (via php-fpm) dan selain itu ke Next.js (port 3000).
# APP_URL = URL publik backend saat di-serve.
APP_URL=https://sibermas.uinsaizu.ac.id/api
# Frontend URL dipakai untuk password-reset link dan URL yang dikirim ke klien.
APP_FRONTEND_URL=https://sibermas.uinsaizu.ac.id

# ─── SIAKAD MASTER API ───────────────────────────────────────
MASTER_API_URL="https://api.uinsaizu.ac.id/api"
MASTER_API_TOKEN=     # Token dari Administrator SIAKAD
MASTER_API_TIMEOUT=30
MASTER_API_CIRCUIT_BREAKER_THRESHOLD=5
MASTER_API_CIRCUIT_BREAKER_TIMEOUT=300
MASTER_WEBHOOK_SECRET=  # Webhook signature verification

# Filter SIAKAD — block Pascasarjana (faculty ID 1) + jenjang S2/S3
SIAKAD_STUDENT_MIN_BATCH_YEAR=0
SIAKAD_STUDENT_SKIP_NON_KKN_JENJANG=true
SIAKAD_STUDENT_BLOCKLIST_NIM_PREFIX=18,19,20
SIAKAD_STUDENT_BLOCKLIST_FAKULTAS_IDS=
SIAKAD_LECTURER_SKIP_TUGAS_BELAJAR=false
SIAKAD_LECTURER_REQUIRE_NUMERIC_NIP=true

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file

# ─── HASHING (gunakan Argon2id di production) ────────────────
# NOTE: BCRYPT_ROUNDS is intentionally omitted — HASHING_DRIVER=argon2id is
# authoritative. Existing bcrypt hashes are rehashed on login (rehash_on_login).
HASHING_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4

# ─── LOG ─────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning         # production: warning, staging: info, dev: debug

# ─── DATABASE ────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1         # Sesuaikan dengan server DB production
DB_PORT=5432
DB_DATABASE=kknnative
DB_USERNAME=kknuinsaizunative        # User PostgreSQL production/native
DB_PASSWORD=kknuinsaizu2026native    # Password PostgreSQL production/native
DB_SSLMODE=prefer          # prefer (coba SSL dulu, fallback non-SSL). Set require kalau PG sudah SSL

# ─── SESSION ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Single-domain path-based deploy → cookie cukup diikat ke host itu sendiri.
# (Tanpa leading-dot supaya tidak bocor ke subdomain yang tidak diinginkan.)
SESSION_DOMAIN=sibermas.uinsaizu.ac.id
SESSION_SECURE_COOKIE=true    # WAJIB true di HTTPS production
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# ─── SERVICES ────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# IMPORTANT: supervisord.conf queue workers use the configured driver below.
# Production uses standard Laravel queue:work via Supervisor (not Horizon).
# Redis is recommended for queue/cache/registration locks; if Redis is
# unavailable, stop supervisord first and switch these stores deliberately.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REGISTRATION_LOCK_CACHE_STORE=redis
REGISTRATION_SNAPSHOT_CACHE_STORE=redis

# Queue jobs include PDF/export/sync workloads that can run longer than the
# default 90s. Keep retry_after greater than the longest job timeout to avoid
# duplicate execution while the first worker is still running.
REDIS_QUEUE_RETRY_AFTER=1200
DB_QUEUE_RETRY_AFTER=1200

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ─── MAIL ────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sibermas@uinsaizu.ac.id
MAIL_PASSWORD=            # App password Gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="sibermas@uinsaizu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

# ─── API KEY SYSTEM ──────────────────────────────────────────
API_ADMIN_SECRET=         # WAJIB diisi! Secret untuk generate API key
API_KEY_RATE_LIMIT=60

ADMIN_EMAIL=admin@uinsaizu.ac.id
BACKUP_NOTIFICATION_EMAIL=

# ─── CORS ────────────────────────────────────────────────────
# Single-domain deploy: web & API berbagi origin yang sama, jadi cukup
# satu entry untuk browser. Mobile clients (Capacitor / Expo dev client)
# tetap butuh origin terdaftar eksplisit karena mereka pakai scheme
# non-http:
#   - capacitor://localhost  → Android/iOS build Capacitor
#   - http://localhost       → Expo dev client / web emulator
# Mobile HARUS pakai Authorization: Bearer <token>, bukan cookie. Untuk
# production browser, jangan sertakan localhost karena boot guard akan menolak
# origin dev saat supports_credentials=true.
CORS_ALLOWED_ORIGINS=https://sibermas.uinsaizu.ac.id

# ─── SANCTUM (API Token Auth) ────────────────────────────────
# Default 43200 minutes (30 days) in config. 10080 (7 days) recommended for
# student/grade systems — see audit finding H-004.
SANCTUM_TOKEN_EXPIRATION=10080
# Stateful (cookie-based SPA auth) hanya untuk web domain tunggal.
# Mobile tidak masuk sini — mobile pakai bearer token stateless.
SANCTUM_STATEFUL_DOMAINS=sibermas.uinsaizu.ac.id

# ─── SENTRY ──────────────────────────────────────────────────
# Leave SENTRY_LARAVEL_DSN empty to disable error reporting.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.2          # Audit L-003: avoid quota exhaustion
SENTRY_TRACES_SAMPLE_RATE=0.0

# ─── AI (Optional) ──────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=

# ─── AI Failover (Avatar Validation + Playground) ─────────────
# 3-tier SumoPod OpenAI-compatible endpoint. Generate 3 DIFFERENT API keys
# in SumoPod dashboard so revocation/rate-limit on one doesn't kill the
# other tiers. Rotate every 90 days.
AI_PRIMARY_URL="https://ai.sumopod.com/v1"
AI_PRIMARY_KEY=
AI_PRIMARY_MODEL="gemini/gemini-2.5-pro"

AI_FALLBACK_URL="https://ai.sumopod.com/v1"
AI_FALLBACK_KEY=
AI_FALLBACK_MODEL="gemini/gemini-2.5-flash"

AI_TERTIARY_URL="https://ai.sumopod.com/v1"
AI_TERTIARY_KEY=
AI_TERTIARY_MODEL="gpt-4o"

# ─── Ops Monitoring (Telegram) ────────────────────────────────
# Bot created via @BotFather. TELEGRAM_CHAT_ID must be populated after
# DMing the bot — run `php artisan monitoring:telegram-chat-id`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── PII Encryption (Phase 2+) ───────────────────────────────
# HMAC key for deterministic blind-index on encrypted NIM/NIP columns.
# Generate with: `php -r "echo base64_encode(random_bytes(32));"`
# MUST be distinct from APP_KEY. Rotating requires re-building all blind
# indexes (see docs/PII_ENCRYPTION_PLAN.md).
APP_BLIND_INDEX_KEY=

# ─── 2FA Grace Period ────────────────────────────────────────
# Jam grace period untuk akun privileged BARU (superadmin / admin / dpl) —
# selama window ini, middleware 2FA tidak blokir akses APAPUN sehingga
# admin baru bisa landing di dashboard lalu setup 2FA. Setelah window
# habis, hanya rute profil + /2fa/* yang terbuka sampai TOTP di-confirm.
# First launch: set 24 (1 hari). Steady state: set 0 (strict).
AUTH_2FA_GRACE_HOURS=24

# ─── Master Webhook Signature ────────────────────────────────
# Shared secret used to verify webhook payloads from the SIAKAD Master API.
# Must match the value configured on the SIAKAD side.
MASTER_WEBHOOK_SECRET=
