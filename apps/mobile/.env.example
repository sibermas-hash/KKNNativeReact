# Mobile (Expo) environment variables.
#
# Copy ke `.env` (untuk dev lokal) atau set sebagai EAS secret / CI var di prod.
# Semua var yang diexpose ke runtime mobile harus prefix EXPO_PUBLIC_.
# DO NOT commit real values into `.env` — hanya file contoh ini yang masuk git.

# --- API ---
# Base URL Laravel backend (termasuk /api/v1 prefix).
EXPO_PUBLIC_API_URL=https://sibermas.uinsaizu.ac.id/api/v1

# --- Sentry (opsional) ---
# Kalau kosong: Sentry di-disable total (no network call). Sentry DSN aman
# untuk dibundle ke client — public secret by design.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=production
# Release tag; kalau kosong jatuh ke app version dari app.config.ts.
EXPO_PUBLIC_APP_VERSION=
