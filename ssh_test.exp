#!/usr/bin/env expect -f
# SSH connection test (requires SSH key auth)
# Usage: SSH_USER=user SSH_HOST=host SSH_PORT=port expect ssh_test.exp
set timeout 30
set env(SSH_USER) [expr {[info exists env(SSH_USER)] ? $env(SSH_USER) : "kampelmas"}]
set env(SSH_HOST) [expr {[info exists env(SSH_HOST)] ? $env(SSH_HOST) : "172.16.2.70"}]
set env(SSH_PORT) [expr {[info exists env(SSH_PORT)] ? $env(SSH_PORT) : "1977"}]
log_file -a ./ssh_output.log
spawn ssh -p $env(SSH_PORT) -o StrictHostKeyChecking=accept-new $env(SSH_USER)@$env(SSH_HOST) "whoami; hostname; pwd; echo SSH_SUCCESS"
expect {
    "SSH_SUCCESS" {
        puts "\nCONNECTION_OK"
    }
    timeout {
        puts "\nTIMEOUT_ERROR"
        exit 1
    }
    eof {
        puts "\nEOF_REACHED"
    }
}
wait
