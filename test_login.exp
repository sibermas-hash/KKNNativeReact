#!/usr/bin/env expect -f
# SSH login test (requires SSH key auth)
log_file ./test_login.log
set timeout 10
spawn ssh -p 1977 -o StrictHostKeyChecking=accept-new kampelmas@172.16.2.70
expect {
    "*$" {
        send "echo LOGGED_IN_SUCCESS\r"
        expect "LOGGED_IN_SUCCESS"
        send "exit\r"
        puts "SUCCESS_LOGIN"
    }
    timeout {
        puts "TIMEOUT"
        exit 1
    }
    eof {
        puts "EOF"
    }
}
